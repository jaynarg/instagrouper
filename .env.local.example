# Copy these into Vercel -> Project -> Settings -> Environment Variables.
# Do NOT commit real values. None of these use the NEXT_PUBLIC_ prefix, so they
# stay server-side only and never reach the browser bundle.

# Supabase: Project Settings -> API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service_role-key

# Anthropic: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional shared passphrase. If set, the app asks for it once before showing
# anything, and every API call must include it. Leave blank/unset to run open.
# Recommended: set this so a stray visitor can't run up your tagging bill.
APP_PASSWORD=
