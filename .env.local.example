# Copy these into Vercel -> Project -> Settings -> Environment Variables.
# Do NOT commit real values. None use the NEXT_PUBLIC_ prefix, so they stay
# server-side only and never reach the browser bundle.

# Supabase: Project Settings -> API
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service_role-key

# Anthropic: console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# WORKSPACES: a JSON map of passphrase -> workspace name. Each person gets a
# passphrase; the server uses it to show only that workspace's posts. Pick long,
# unguessable passphrases. Example (note the whole thing is one line):
# {"correct-horse-battery-staple":"jay","purple-saffron-2026":"mom"}
WORKSPACES={"change-me-jay":"jay"}

# HANDLES (optional): JSON map of workspace -> Instagram handle, shown as
# "Account: @handle" at the top of the page. The saved-posts export does NOT
# contain your own handle, so set it here. Omit to show the workspace name instead.
# {"jay":"jayguevara25","mom":"her_handle"}
HANDLES={"jay":"jayguevara25"}
